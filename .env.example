# ─────────────────────────────────────────────────────────────
# Firebase (Firestore + Anonymous Auth) 설정
# ─────────────────────────────────────────────────────────────
# 아래 값을 채운 .env(또는 .env.local) 파일을 만들면 Firestore 가 기본 저장소가 됩니다.
# 값이 하나라도 비어 있으면 앱은 기존처럼 LocalStorage 로만 동작합니다(하위 호환).
#
# 값 얻는 곳: Firebase Console → 프로젝트 → ⚙ 프로젝트 설정 → "내 앱"의 웹 앱(</>) → SDK 설정 및 구성
#   (웹 앱이 없으면 "앱 추가 → 웹" 으로 하나 만드세요)
#
# 사전 준비(Firebase Console):
#   1) Authentication → Sign-in method → "익명(Anonymous)" 사용 설정
#   2) Firestore Database → 데이터베이스 만들기(프로덕션/테스트 모드)
#   3) (권장) Firestore 보안 규칙: owner==request.auth.uid 문서만 접근 허용
#   4) Authentication → Settings → 승인된 도메인에 배포 도메인 추가

VITE_FIREBASE_API_KEY=              # firebaseConfig.apiKey
VITE_FIREBASE_AUTH_DOMAIN=          # firebaseConfig.authDomain  (예: your-app.firebaseapp.com)
VITE_FIREBASE_PROJECT_ID=          # firebaseConfig.projectId
VITE_FIREBASE_STORAGE_BUCKET=      # firebaseConfig.storageBucket (선택, 이번 단계 미사용)
VITE_FIREBASE_MESSAGING_SENDER_ID= # firebaseConfig.messagingSenderId (선택)
VITE_FIREBASE_APP_ID=              # firebaseConfig.appId

# ─────────────────────────────────────────────────────────────
# Supabase 설정 (선택)
# ─────────────────────────────────────────────────────────────
# 값 얻는 곳: Supabase Dashboard → 프로젝트 → Project Settings → API
#   - Project URL → VITE_SUPABASE_URL
#   - publishable(공개용) 키 → VITE_SUPABASE_ANON_KEY (프론트엔드 노출 가능)
VITE_SUPABASE_URL=                 # 예: https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=            # publishable(공개용) 키
# ⚠️ service_role 키는 절대 프론트엔드/.env(VITE_*)에 넣지 마세요. publishable 키만 사용합니다.
#
# 사전 준비(Supabase Dashboard):
#   1) Authentication → Sign In / Providers → "Allow anonymous sign-ins" ON → Save
#   2) SQL Editor 에서 supabase/migrations/001_initial_storage.sql 실행(테이블/RLS/RPC 생성)

# ─────────────────────────────────────────────────────────────
# 저장소 provider 선택
# ─────────────────────────────────────────────────────────────
# firebase | supabase | local  (기본값: firebase)
#   - firebase : Firestore + LocalStorage 캐시 (기존 동작)
#   - supabase : Supabase(Postgres) + LocalStorage 캐시 (위 Supabase 설정 필요)
#   - local    : LocalStorage 전용
#   - 선택한 클라우드 설정(env)이 없으면 자동으로 local 로 폴백
VITE_STORAGE_PROVIDER=firebase

# ─────────────────────────────────────────────────────────────
# 로컬 전용 Firestore→Supabase 이전 도구(/migrate)
# ─────────────────────────────────────────────────────────────
# true 일 때만 /migrate 화면이 활성화됩니다(메뉴에는 노출 안 됨, 직접 접근).
# ⚠️ production 빌드에서는 반드시 false 로 두세요(기본값 false).
VITE_ENABLE_MIGRATION_TOOL=false
