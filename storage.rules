rules_version = '2';

// Booth Layout Planner — 3D 모델(GLB/GLTF) 저장 규칙 (v1.1.5)
// - models/{uid}/*: 공유 뷰어도 볼 수 있게 공개 읽기, 쓰기는 본인(uid)만 · 20MB 제한.
service firebase.storage {
  match /b/{bucket}/o {
    match /models/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 20 * 1024 * 1024;
    }
    // 그 외 경로는 모두 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
